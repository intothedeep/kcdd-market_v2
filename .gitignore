# Database backups (may contain personal data)
backend/supabase/backups/

# backend/pnpm-workspace.yaml is auto-regenerated by pnpm 11 when it asks
# about build script approvals, but committing it breaks CI install (pnpm
# walks up from backend/api/ to find the file, treats backend/ as a
# workspace root without listing api/ as a member, then installs at
# backend/node_modules instead of backend/api/node_modules → CI can't find
# prettier/eslint). The supabase build approval already lives in
# backend/package.json's `pnpm.onlyBuiltDependencies` field, so this file
# is redundant. Keep it out of git. See commit 9a1df88 (H7 fix).
backend/pnpm-workspace.yaml
