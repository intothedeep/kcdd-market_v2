{
  "name": "kcdd-market-backend",
  "version": "1.0.0",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "db:start": "[ -S /var/run/docker.sock ] || sudo ln -sf $HOME/.colima/default/docker.sock /var/run/docker.sock && pnpx supabase start",
    "db:stop": "pnpx supabase stop",
    "db:status": "pnpx supabase status",
    "db:reset": "pnpx supabase db reset",
    "db:reset:linked": "pnpx supabase db reset --linked",
    "db:push:linked": "pnpx supabase db push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7"
  },
  "devDependencies": {
    "supabase": "2.98.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
