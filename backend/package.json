{
  "name": "kcdd-market-backend",
  "version": "1.0.0",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "db:start": "[ -S /var/run/docker.sock ] || sudo ln -sf $HOME/.colima/default/docker.sock /var/run/docker.sock && supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:status": "supabase status",
    "backfill:images": "node scripts/backfill-base64-images.mjs",
    "backfill:images:dry": "node scripts/backfill-base64-images.mjs --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7"
  },
  "devDependencies": {
    "supabase": "2.98.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
