# ==============================================================================
# Backend API — environment variables
# ==============================================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored.

# ------------------------------------------------------------------------------
# Supabase — DB + secret (service role) key for admin-level operations
# (webhooks, /users/sync). Never expose to frontend.
# ------------------------------------------------------------------------------
# macOS / Colima: use 127.0.0.1, NOT localhost. `localhost` resolves to IPv6
# `::1` first, but the local Supabase gateway binds IPv4 only, so a Node fetch
# can throw `TypeError: fetch failed ... ECONNREFUSED`. 127.0.0.1 forces IPv4.
SUPABASE_URL=http://127.0.0.1:54321
# Supabase 2024+ naming: SUPABASE_SECRET_KEY (formerly SUPABASE_SERVICE_ROLE_KEY).
# Local Docker stack ships a fixed dev key; run `pnpm db:status` from backend/
# and copy the `service_role key` / `secret key` value.
SUPABASE_SECRET_KEY=sb_secret_...

# ------------------------------------------------------------------------------
# Clerk — server-side JWT verification (clerkAuth middleware) + /users/sync
# ------------------------------------------------------------------------------
# Dashboard: https://dashboard.clerk.com → app → API Keys → Secret keys
CLERK_SECRET_KEY=sk_test_...

# ------------------------------------------------------------------------------
# Dev role bootstrap (OPTIONAL, DEV ONLY) — auto-assign roles on Clerk sign-in
# ------------------------------------------------------------------------------
# When NODE_ENV !== 'production', POST /api/users/sync looks up the signed-in
# user's email via the Clerk API and, if it matches an entry below, FORCE-sets
# that user's user_type. Lets teammates get admin / cbo / donor by simply
# signing in, and it re-applies automatically after `pnpm db:reset` (no manual
# SQL). PRODUCTION-SAFE: this variable is ignored when NODE_ENV=production.
#
#   Format : comma-separated `email:role` pairs
#   Roles  : admin | cbo | donor
#   Needs  : CLERK_SECRET_KEY (used to resolve the email)
#
# Notes:
#   * Mock seed accounts (admin@kcdd.local, donor1@example.com, ...) CANNOT be
#     logged into — they are DB rows with no Clerk credentials. Only real Clerk
#     sign-ins receive a role here.
#   * node --watch does NOT reload .env — after editing this value you MUST
#     restart the backend (Ctrl+C in the `pnpm dev` terminal, then re-run it),
#     or the override silently won't apply.
DEV_ROLE_OVERRIDES="taek.lim.us@gmail.com:admin,txl25880@ucmo.edu:donor,mysites.victor@gmail.com:cbo"

# ------------------------------------------------------------------------------
# Stripe — payment intents + webhook signature verification
# ------------------------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Local dev: from `stripe listen --forward-to localhost:4000/api/payments/webhook`
# Prod: from Stripe Dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Dev only: skip Stripe Connect destination charges so donations work without each
# org having a connected Stripe account. Without this, /api/payments/create-intent
# returns 400 STRIPE_NOT_CONNECTED for any org missing
# stripe_account_id / stripe_charges_enabled=true.
# NEVER set in production — payments must route through Connect there.
STRIPE_BYPASS_CONNECT=true

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development

# ------------------------------------------------------------------------------
# Payment metadata — used by backend/api/helpers/paymentMetadata.js
# (PH-2: payment_transactions.metadata snapshot + lifecycle)
# ------------------------------------------------------------------------------
# REQUIRED in production. SHA-256 salt for hashing donor IP into
# payment_transactions.metadata.client.ip_hash. Without a real salt an
# attacker can pre-compute IP→hash for the IPv4 space (~4.3B entries) and
# reverse our hashes. In dev the code falls back to 'dev-only-replace-in-prod'
# so this can stay unset locally — but production MUST set it.
# Generate: `openssl rand -hex 32`
IP_HASH_SALT=

# RECOMMENDED. Stamped into metadata.diagnostics.backend_version so we can
# trace "which build processed this payment" — invaluable when debugging a
# receipt-pipeline regression or webhook drift across deploys. On Vercel set
# this to ${VERCEL_GIT_COMMIT_SHA} in the project env config. Falls back to
# "unknown" when unset.
GIT_SHA=

# ------------------------------------------------------------------------------
# Slack admin alerts — Phase A6 (slack_notification_queue + cron flush)
# See howtoexecute.local.md "Testing Slack admin alerts locally" for local
# recipe; howtodeploy.prod.md Step 5 for production setup.
# ------------------------------------------------------------------------------
# REQUIRED for the /api/cron/flush-slack-queue route. Without it the route
# returns 401 on every call. Generate: `openssl rand -hex 32`
CRON_SECRET=

# OPTIONAL. Slack Incoming Webhook URL. When set, the cron POSTs alert bodies
# here. When unset (dev / preview without secret), postToSlack logs to stdout
# as `[slack:dev] {...}` and the queue row still flips to status='sent' —
# letting local flows exercise the queue + cron auth round-trip without a real
# workspace. Format: https://hooks.slack.com/services/<team>/<bot>/<token>
SLACK_WEBHOOK_URL=

# OPTIONAL but recommended. Used as the link prefix in Slack alert bodies
# (e.g. `<APP_URL>/admin/pending-edits/<id>`). Falls back to '' so links still
# render but resolve relative to whatever host the message is opened from.
APP_URL=http://localhost:3000
